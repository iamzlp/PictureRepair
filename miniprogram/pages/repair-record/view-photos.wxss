.page {
  min-height: 100vh;
  padding: 28rpx 28rpx 200rpx;
  box-sizing: border-box;
  background: #fcf9f8;
}

.frame {
  width: 100%;
  height: 820rpx;
  border-radius: 24rpx;
  overflow: hidden;
  background: #eae7e7;
  position: relative;
}

.image {
  width: 100%;
  height: 100%;
}

.placeholder {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #827470;
  font-size: 28rpx;
  font-weight: 600;
}

.badge {
  position: absolute;
  left: 18rpx;
  top: 18rpx;
  padding: 10rpx 16rpx;
  border-radius: 999rpx;
  background: rgba(252, 249, 248, 0.88);
  border: 1rpx solid rgba(212, 195, 190, 0.6);
  font-size: 22rpx;
  color: #442a22;
}

.action-row {
  margin-top: 28rpx;
  display: flex;
  gap: 18rpx;
}

.download-btn,
.video-btn {
  margin-top: 0;
  width: 100%;
  height: 96rpx;
  padding: 0;
  margin-left: 0;
  margin-right: 0;
  border-radius: 16rpx;
  font-size: 30rpx;
  font-weight: 800;
  display: flex;
  align-items: center;
  justify-content: center;
  text-align: center;
  box-sizing: border-box;
}

.half {
  flex: 1 1 0;
  width: 0;
  min-width: 0;
}

.download-btn {
  background: #002e68;
  color: #ffffff;
}

.video-btn {
  background: #442a22;
  color: #ffffff;
}

.download-btn[disabled],
.video-btn[disabled] {
  opacity: 0.45;
}

.download-btn::after,
.video-btn::after,
.regenerate-btn::after,
.download-video-btn::after {
  border: 0;
}

.download-tip {
  margin-top: 10rpx;
  text-align: center;
  font-size: 24rpx;
  color: #504441;
}

.regenerate-btn {
  margin-top: 18rpx;
  width: 100%;
  height: 88rpx;
  padding: 0;
  border-radius: 16rpx;
  background: #fffaf8;
  border: 2rpx solid rgba(130, 116, 112, 0.5);
  color: #6a554d;
  font-size: 28rpx;
  font-weight: 800;
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
}

.regenerate-btn[disabled] {
  opacity: 0.45;
}

.section {
  margin-top: 30rpx;
}

.section-head {
  display: flex;
  justify-content: space-between;
  align-items: baseline;
  gap: 18rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 800;
  color: #1b1c1c;
}

.section-meta {
  font-size: 24rpx;
  color: #504441;
}

.section-meta.error {
  color: #ba1a1a;
}

.video-box {
  margin-top: 18rpx;
  width: 100%;
  height: 420rpx;
  border-radius: 18rpx;
  overflow: hidden;
  border: 1rpx solid rgba(212, 195, 190, 0.7);
  background: #e4e2e1;
}

.video-player {
  width: 100%;
  height: 100%;
}

.video-placeholder {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  text-align: center;
  padding: 0 36rpx;
  box-sizing: border-box;
  color: #504441;
  font-size: 28rpx;
  font-weight: 600;
}

.download-video-btn {
  margin-top: 18rpx;
  width: 100%;
  height: 92rpx;
  padding: 0;
  border-radius: 16rpx;
  background: #0d6b47;
  color: #ffffff;
  font-size: 30rpx;
  font-weight: 800;
  display: flex;
  align-items: center;
  justify-content: center;
}

.origin {
  margin-top: 18rpx;
  width: 50%;
  height: 360rpx;
  border-radius: 18rpx;
  overflow: hidden;
  border: 1rpx solid rgba(212, 195, 190, 0.7);
  background: #e4e2e1;
}

.origin-img {
  width: 100%;
  height: 100%;
}

.back-btn {
  margin-top: 34rpx;
  width: 100%;
  height: 92rpx;
  padding: 0;
  margin-left: 0;
  margin-right: 0;
  border-radius: 16rpx;
  background: transparent;
  border: 2rpx solid #827470;
  color: #504441;
  font-size: 30rpx;
  font-weight: 800;
  display: flex;
  align-items: center;
  justify-content: center;
  text-align: center;
  box-sizing: border-box;
}

.back-btn::after {
  border: 0;
}

