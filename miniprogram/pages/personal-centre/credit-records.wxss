.page {
  min-height: 100vh;
  padding: 28rpx 28rpx 200rpx;
  box-sizing: border-box;
  background: #fcf9f8;
}

.loading,
.empty {
  padding: 80rpx 0;
  text-align: center;
  color: #504441;
}

.list {
  display: flex;
  flex-direction: column;
  gap: 22rpx;
  margin-top: 10rpx;
}

.item {
  background: #ffffff;
  border-radius: 24rpx;
  border: 1rpx solid rgba(212, 195, 190, 0.55);
  box-shadow: 0 8rpx 30rpx rgba(68, 42, 34, 0.08);
  padding: 24rpx 26rpx;
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 20rpx;
}

.left {
  flex: 1;
  min-width: 0;
}

.time {
  font-size: 24rpx;
  color: rgba(80, 68, 65, 0.6);
}

.name-row {
  margin-top: 8rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.name {
  font-size: 28rpx;
  font-weight: 800;
  color: #442a22;
}

.balance {
  flex-shrink: 0;
  font-size: 22rpx;
  color: rgba(80, 68, 65, 0.7);
}

.description {
  margin-top: 10rpx;
  font-size: 24rpx;
  line-height: 1.6;
  color: rgba(80, 68, 65, 0.82);
}

.amount {
  flex-shrink: 0;
  font-size: 34rpx;
  font-weight: 900;
}

.amount.plus {
  color: #2f8f5b;
}

.amount.minus {
  color: #b44a3c;
}

.more-btn {
  margin-top: 42rpx;
  width: 100%;
  height: 84rpx;
  padding: 0;
  border-radius: 999rpx;
  border: 1rpx solid rgba(130, 116, 112, 0.55);
  background: transparent;
  color: #504441;
  font-size: 28rpx;
  font-weight: 800;
  display: flex;
  align-items: center;
  justify-content: center;
}

.more-btn::after {
  border: 0;
}

.more-btn[disabled] {
  opacity: 0.5;
}

.arrow {
  margin-left: 10rpx;
  line-height: 1;
}
