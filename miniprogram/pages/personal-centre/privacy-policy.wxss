.page {
  min-height: 100vh;
  padding: 28rpx 28rpx 200rpx;
  box-sizing: border-box;
  background: #fcf9f8;
}

.hero {
  padding: 14rpx 0 18rpx;
}

.hero-kicker {
  font-size: 22rpx;
  color: rgba(68, 42, 34, 0.6);
}

.hero-title {
  margin-top: 10rpx;
  font-size: 34rpx;
  font-weight: 900;
  color: #442a22;
}

.card {
  margin-top: 18rpx;
  background: rgba(255, 255, 255, 0.92);
  border-radius: 24rpx;
  border: 1rpx solid rgba(212, 195, 190, 0.5);
  box-shadow: 0 8rpx 30rpx rgba(68, 42, 34, 0.08);
  padding: 26rpx;
}

.section {
  margin-bottom: 24rpx;
}

.section-title {
  font-size: 28rpx;
  font-weight: 900;
  color: #1b1c1c;
}

.text {
  margin-top: 10rpx;
  font-size: 26rpx;
  line-height: 1.7;
  color: #504441;
}

.bullet {
  margin-top: 10rpx;
  font-size: 26rpx;
  line-height: 1.6;
  color: #504441;
}
