<view class="page">
  <view class="title">个人中心</view>

  <view class="card profile">
    <button class="avatar-btn" open-type="chooseAvatar" bindchooseavatar="onChooseAvatar" loading="{{savingAvatar}}" disabled="{{savingAvatar}}">
      <image wx:if="{{avatarDraft}}" class="avatar-img" src="{{avatarDraft}}" mode="aspectFill" binderror="onAvatarError"></image>
      <view wx:else class="avatar-empty">点击设置头像</view>
    </button>
    <view class="profile-body">
      <input
        class="name-input"
        type="nickname"
        value="{{nicknameDraft}}"
        placeholder="游客"
        bindinput="onNicknameInput"
        bindblur="onNicknameBlur"
      />
      <view class="badge">☆ 免费会员</view>
    </view>
  </view>

  <view class="stats">
    <view class="card stat">
      <view class="stat-value">{{repairedCount}}</view>
      <view class="stat-label">已修复照片</view>
    </view>
    <view class="card stat">
      <view class="stat-value blue">{{balance}}</view>
      <view class="stat-label">剩余次数</view>
    </view>
  </view>

  <button class="recharge-btn" bindtap="goRecharge">立即充值</button>

  <view class="card menu">
    <view class="menu-item" bindtap="goRechargeRecords">
      <view class="menu-left">🧾 充值记录</view>
      <view class="menu-right">›</view>
    </view>
    <view class="menu-item" bindtap="goCreditRecords">
      <view class="menu-left">🪙 点数记录</view>
      <view class="menu-right">›</view>
    </view>
    <view class="menu-item" bindtap="goServiceAgreement">
      <view class="menu-left">📄 服务协议</view>
      <view class="menu-right">›</view>
    </view>
    <view class="menu-item" bindtap="goPrivacyPolicy">
      <view class="menu-left">ⓘ 隐私政策</view>
      <view class="menu-right">›</view>
    </view>
    <view class="menu-item last" bindtap="goHelp">
      <view class="menu-left">？ 帮助与反馈</view>
      <view class="menu-right">›</view>
    </view>
  </view>

  <button class="logout-btn" bindtap="onLogout">退出登录</button>
</view>
