.page {
  min-height: 100vh;
  background: rgba(0, 0, 0, 0.55);
  display: flex;
  align-items: flex-end;
  justify-content: center;
  padding: 0 28rpx 0;
  box-sizing: border-box;
}

.mask {
  position: fixed;
  inset: 0;
}

.card {
  position: relative;
  width: 100%;
  background: #fcf9f8;
  border-top-left-radius: 32rpx;
  border-top-right-radius: 32rpx;
  padding: 34rpx 28rpx 40rpx;
  box-sizing: border-box;
}

.close {
  position: absolute;
  right: 22rpx;
  top: 22rpx;
  width: 72rpx;
  height: 72rpx;
  border-radius: 36rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  color: #1b1c1c;
}

.dot {
  width: 72rpx;
  height: 72rpx;
  border-radius: 36rpx;
  background: rgba(68, 42, 34, 0.22);
  margin: 0 auto;
}

.title {
  margin-top: 22rpx;
  font-size: 44rpx;
  font-weight: 900;
  text-align: center;
  color: #1b1c1c;
}

.subtitle {
  margin-top: 14rpx;
  font-size: 26rpx;
  text-align: center;
  color: #504441;
}

.plans {
  margin-top: 26rpx;
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.plan {
  position: relative;
  padding: 22rpx;
  border-radius: 18rpx;
  background: #ffffff;
  border: 1rpx solid rgba(212, 195, 190, 0.8);
  display: flex;
  align-items: center;
  gap: 18rpx;
}

.plan.active {
  border: 2rpx solid #002e68;
  background: rgba(0, 46, 104, 0.04);
}

.radio {
  width: 28rpx;
  height: 28rpx;
  border-radius: 14rpx;
  border: 2rpx solid rgba(130, 116, 112, 0.8);
  box-sizing: border-box;
}

.radio.on {
  border-color: #002e68;
  box-shadow: inset 0 0 0 6rpx #002e68;
}

.plan-body {
  flex: 1;
}

.plan-name {
  font-size: 30rpx;
  font-weight: 900;
  color: #1b1c1c;
}

.plan-desc {
  margin-top: 6rpx;
  font-size: 24rpx;
  color: #504441;
}

.plan-price {
  text-align: right;
}

.price-main {
  font-size: 36rpx;
  font-weight: 900;
  color: #1b1c1c;
}

.price-sub {
  margin-top: 6rpx;
  font-size: 22rpx;
  color: #504441;
}

.badge {
  position: absolute;
  right: 18rpx;
  top: -14rpx;
  padding: 6rpx 14rpx;
  border-radius: 999rpx;
  background: #002e68;
  color: #ffffff;
  font-size: 22rpx;
  font-weight: 800;
}

.pay-btn {
  margin-top: 30rpx;
  width: 100%;
  height: 96rpx;
  line-height: 96rpx;
  border-radius: 18rpx;
  background: #16b65a;
  color: #ffffff;
  font-size: 30rpx;
  font-weight: 900;
}

.pay-btn[disabled] {
  opacity: 0.5;
}

.pay-tip {
  margin-top: 16rpx;
  text-align: center;
  font-size: 24rpx;
  color: #827470;
}

