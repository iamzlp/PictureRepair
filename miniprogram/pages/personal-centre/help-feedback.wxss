.page {
  min-height: 100vh;
  padding: 28rpx 28rpx 200rpx;
  box-sizing: border-box;
  background: #fcf9f8;
}

.hero {
  text-align: center;
  padding: 18rpx 0 14rpx;
}

.hero-icon {
  width: 120rpx;
  height: 120rpx;
  border-radius: 60rpx;
  margin: 0 auto;
  background: rgba(255, 218, 214, 0.75);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 52rpx;
  line-height: 1;
  color: #442a22;
}

.hero-title {
  margin-top: 20rpx;
  font-size: 44rpx;
  font-weight: 900;
  color: #1b1c1c;
}

.hero-sub {
  margin-top: 12rpx;
  font-size: 26rpx;
  line-height: 1.6;
  color: #504441;
}

.section {
  margin-top: 26rpx;
}

.section-head {
  font-size: 26rpx;
  font-weight: 900;
  color: #442a22;
  margin-bottom: 16rpx;
}

.faq {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.faq-item {
  background: #ffffff;
  border-radius: 18rpx;
  border: 1rpx solid rgba(212, 195, 190, 0.5);
  padding: 22rpx;
  box-shadow: 0 8rpx 30rpx rgba(68, 42, 34, 0.08);
}

.faq-title {
  font-size: 28rpx;
  font-weight: 900;
  color: #1b1c1c;
}

.faq-desc {
  margin-top: 10rpx;
  font-size: 24rpx;
  line-height: 1.55;
  color: #504441;
}

.form {
  background: #ffffff;
  border-radius: 18rpx;
  border: 1rpx solid rgba(212, 195, 190, 0.5);
  box-shadow: 0 8rpx 30rpx rgba(68, 42, 34, 0.08);
  overflow: hidden;
}

.form-row {
  padding: 22rpx;
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.form-row.col {
  flex-direction: column;
  align-items: flex-start;
}

.label {
  width: 140rpx;
  font-size: 26rpx;
  font-weight: 800;
  color: #1b1c1c;
}

.picker {
  flex: 1;
}

.picker-value {
  font-size: 26rpx;
  color: #504441;
}

.chev {
  color: rgba(80, 68, 65, 0.35);
}

.divider {
  height: 1rpx;
  background: rgba(240, 237, 237, 1);
}

.textarea {
  width: 100%;
  min-height: 220rpx;
  font-size: 26rpx;
  line-height: 1.55;
  color: #1b1c1c;
}

.submit-btn {
  margin-top: 18rpx;
  width: 100%;
  height: 92rpx;
  padding: 0;
  border-radius: 18rpx;
  background: #442a22;
  color: #ffffff;
  font-size: 30rpx;
  font-weight: 900;
  display: flex;
  align-items: center;
  justify-content: center;
}

.submit-btn::after {
  border: 0;
}

.submit-success-card {
  margin-top: 18rpx;
  padding: 20rpx 22rpx;
  border-radius: 18rpx;
  background: rgba(0, 46, 104, 0.06);
  border: 1rpx solid rgba(0, 46, 104, 0.12);
}

.submit-success-title {
  font-size: 26rpx;
  font-weight: 900;
  color: #002e68;
}

.submit-success-desc {
  margin-top: 10rpx;
  font-size: 24rpx;
  line-height: 1.55;
  color: #504441;
}

.feedback-id-row {
  margin-top: 16rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.feedback-id-text {
  flex: 1;
  min-width: 0;
  font-size: 22rpx;
  color: #1b1c1c;
  word-break: break-all;
}

.copy-btn {
  flex: 0 0 auto;
  min-width: 148rpx;
  height: 64rpx;
  padding: 0 22rpx;
  border-radius: 999rpx;
  background: #ffffff;
  border: 1rpx solid rgba(0, 46, 104, 0.16);
  color: #002e68;
  font-size: 24rpx;
  font-weight: 800;
  display: flex;
  align-items: center;
  justify-content: center;
}

.copy-btn::after {
  border: 0;
}

.support {
  margin-top: 26rpx;
  background: rgba(144, 181, 255, 0.35);
  border-radius: 22rpx;
  padding: 22rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
}

.support-title {
  font-size: 28rpx;
  font-weight: 900;
  color: #1b1c1c;
}

.support-desc {
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #504441;
}

.support-note {
  margin-top: 8rpx;
  font-size: 22rpx;
  color: #002e68;
  word-break: break-all;
}

.support-btn {
  min-width: 220rpx;
  height: 72rpx;
  padding: 0 28rpx;
  border-radius: 999rpx;
  background: #002e68;
  color: #ffffff;
  font-size: 26rpx;
  font-weight: 900;
  display: flex;
  align-items: center;
  justify-content: center;
}

.support-btn::after {
  border: 0;
}
