<view class="page">
  <view class="mask"></view>
  <view class="card">
    <view class="close" bindtap="onClose">×</view>
    <view class="title">登录授权</view>
    <view class="subtitle">请使用当前微信账号授权手机号完成登录。</view>

    <button class="login-btn" open-type="getPhoneNumber" bindgetphonenumber="onWechatLogin" loading="{{loggingIn}}">
      <view class="login-btn-text">微信授权手机号并登录</view>
    </button>

    <view class="agree-row" bindtap="toggleAgree">
      <view class="checkbox {{agreed ? 'checked' : ''}}"></view>
      <view class="agree-text">
        <text>登录即代表同意 </text>
        <text class="link" bindtap="openServiceAgreement">用户协议</text>
        <text> 和 </text>
        <text class="link" bindtap="openPrivacyPolicy">隐私政策</text>
        <text>，并使用当前微信身份创建或登录用户。</text>
      </view>
    </view>
  </view>
</view>
