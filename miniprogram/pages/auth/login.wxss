.page {
  min-height: 100vh;
  background: rgba(0, 0, 0, 0.55);
  display: flex;
  align-items: flex-end;
  justify-content: center;
  padding: 0 28rpx 72rpx;
  box-sizing: border-box;
}

.mask {
  position: fixed;
  inset: 0;
}

.card {
  position: relative;
  width: 100%;
  max-width: 640rpx;
  background: #fcf9f8;
  border-radius: 28rpx;
  padding: 44rpx 34rpx 34rpx;
  box-sizing: border-box;
}

.close {
  position: absolute;
  right: 22rpx;
  top: 22rpx;
  width: 72rpx;
  height: 72rpx;
  border-radius: 36rpx;
  background: rgba(0, 0, 0, 0.06);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  color: #1b1c1c;
}

.title {
  margin-top: 4rpx;
  font-size: 44rpx;
  font-weight: 800;
  text-align: center;
  color: #1b1c1c;
}

.subtitle {
  margin-top: 18rpx;
  font-size: 26rpx;
  line-height: 1.55;
  text-align: center;
  color: #504441;
}

.login-btn {
  margin-top: 32rpx;
  width: 100%;
  height: 96rpx;
  border-radius: 999rpx;
  background: #16b65a;
  color: #ffffff;
  font-size: 30rpx;
  font-weight: 700;
  border: none;
  padding: 0;
  display: flex;
  align-items: center;
  justify-content: center;
}

.login-btn::after {
  border: none;
}

.login-btn-text {
  line-height: 1;
}

.agree-row {
  margin-top: 26rpx;
  display: flex;
  gap: 16rpx;
  align-items: flex-start;
}

.checkbox {
  width: 30rpx;
  height: 30rpx;
  border-radius: 6rpx;
  border: 2rpx solid #d4c3be;
  margin-top: 6rpx;
  box-sizing: border-box;
}

.checkbox.checked {
  background: #16b65a;
  border-color: #16b65a;
}

.agree-text {
  flex: 1;
  font-size: 24rpx;
  line-height: 1.55;
  color: #504441;
}

.link {
  color: #002e68;
  text-decoration: underline;
}

.dialog-mask {
  position: fixed;
  inset: 0;
  background: rgba(0, 0, 0, 0.45);
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 40rpx;
  box-sizing: border-box;
  z-index: 20;
}

.dialog {
  width: 100%;
  background: #ffffff;
  border-radius: 24rpx;
  padding: 34rpx 28rpx 28rpx;
  box-sizing: border-box;
}

.dialog-title {
  font-size: 34rpx;
  font-weight: 800;
  color: #1b1c1c;
  text-align: center;
}

.dialog-content {
  margin-top: 18rpx;
  font-size: 28rpx;
  line-height: 1.6;
  color: #504441;
  text-align: center;
}

.dialog-link {
  color: #002e68;
  text-decoration: underline;
}

.dialog-actions {
  margin-top: 30rpx;
  display: flex;
  gap: 16rpx;
}

.dialog-btn {
  flex: 1;
  height: 84rpx;
  padding: 0;
  border-radius: 18rpx;
  font-size: 28rpx;
  font-weight: 800;
  display: flex;
  align-items: center;
  justify-content: center;
}

.dialog-btn::after {
  border: 0;
}

.dialog-cancel {
  background: #f3efee;
  color: #504441;
}

.dialog-confirm {
  background: #16b65a;
  color: #ffffff;
}
