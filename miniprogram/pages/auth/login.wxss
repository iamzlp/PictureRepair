.page {
  min-height: 100vh;
  background: rgba(0, 0, 0, 0.55);
  display: flex;
  align-items: flex-end;
  justify-content: center;
  padding: 0 28rpx 72rpx;
  box-sizing: border-box;
}

.mask {
  position: fixed;
  inset: 0;
}

.card {
  position: relative;
  width: 100%;
  max-width: 640rpx;
  background: #fcf9f8;
  border-radius: 28rpx;
  padding: 44rpx 34rpx 34rpx;
  box-sizing: border-box;
}

.close {
  position: absolute;
  right: 22rpx;
  top: 22rpx;
  width: 72rpx;
  height: 72rpx;
  border-radius: 36rpx;
  background: rgba(0, 0, 0, 0.06);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  color: #1b1c1c;
}

.logo {
  width: 136rpx;
  height: 136rpx;
  border-radius: 28rpx;
  margin: 0 auto;
  background: linear-gradient(135deg, rgba(68, 42, 34, 0.25), rgba(0, 46, 104, 0.15));
}

.title {
  margin-top: 30rpx;
  font-size: 44rpx;
  font-weight: 800;
  text-align: center;
  color: #1b1c1c;
}

.subtitle {
  margin-top: 18rpx;
  font-size: 26rpx;
  line-height: 1.55;
  text-align: center;
  color: #504441;
}

.login-btn {
  margin-top: 36rpx;
  width: 100%;
  height: 96rpx;
  line-height: 96rpx;
  border-radius: 999rpx;
  background: #16b65a;
  color: #ffffff;
  font-size: 30rpx;
  font-weight: 700;
}

.agree-row {
  margin-top: 26rpx;
  display: flex;
  gap: 16rpx;
  align-items: flex-start;
}

.checkbox {
  width: 30rpx;
  height: 30rpx;
  border-radius: 6rpx;
  border: 2rpx solid #d4c3be;
  margin-top: 6rpx;
  box-sizing: border-box;
}

.checkbox.checked {
  background: #16b65a;
  border-color: #16b65a;
}

.agree-text {
  flex: 1;
  font-size: 24rpx;
  line-height: 1.55;
  color: #504441;
}

.link {
  color: #002e68;
  text-decoration: underline;
}
