.page {
  min-height: 100vh;
  background: rgba(0, 0, 0, 0.55);
  display: flex;
  align-items: flex-end;
  justify-content: center;
  padding: 0 28rpx 72rpx;
  box-sizing: border-box;
}

.mask {
  position: fixed;
  inset: 0;
}

.card {
  position: relative;
  width: 100%;
  max-width: 640rpx;
  background: #fcf9f8;
  border-radius: 28rpx;
  padding: 44rpx 34rpx 34rpx;
  box-sizing: border-box;
}

.close {
  position: absolute;
  right: 22rpx;
  top: 22rpx;
  width: 72rpx;
  height: 72rpx;
  border-radius: 36rpx;
  background: rgba(0, 0, 0, 0.06);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  color: #1b1c1c;
}

.title {
  margin-top: 4rpx;
  font-size: 44rpx;
  font-weight: 800;
  text-align: center;
  color: #1b1c1c;
}

.subtitle {
  margin-top: 18rpx;
  font-size: 26rpx;
  line-height: 1.55;
  text-align: center;
  color: #504441;
}

.profile-form {
  margin-top: 28rpx;
}

.avatar-picker {
  width: 160rpx;
  height: 160rpx;
  margin: 0 auto;
  padding: 0;
  border: none;
  background: transparent;
  display: flex;
  align-items: center;
  justify-content: center;
}

.avatar-picker::after {
  border: none;
}

.avatar-preview,
.avatar-placeholder {
  width: 160rpx;
  height: 160rpx;
  border-radius: 80rpx;
}

.avatar-preview {
  display: block;
  border: 4rpx solid rgba(185, 120, 106, 0.3);
}

.avatar-placeholder {
  box-sizing: border-box;
  border: 2rpx dashed #d7c4bd;
  background: rgba(0, 0, 0, 0.03);
  color: #6a5b56;
  font-size: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  text-align: center;
  padding: 0 18rpx;
}

.nickname-input {
  margin-top: 22rpx;
  width: 100%;
  height: 92rpx;
  border-radius: 22rpx;
  background: #ffffff;
  border: 2rpx solid #eadfd9;
  box-sizing: border-box;
  padding: 0 28rpx;
  font-size: 28rpx;
  color: #1b1c1c;
}

.login-btn {
  margin-top: 36rpx;
  width: 100%;
  height: 96rpx;
  border-radius: 999rpx;
  background: #16b65a;
  color: #ffffff;
  font-size: 30rpx;
  font-weight: 700;
  border: none;
  padding: 0;
  display: flex;
  align-items: center;
  justify-content: center;
}

.login-btn::after {
  border: none;
}

.login-btn-text {
  line-height: 1;
}

.agree-row {
  margin-top: 26rpx;
  display: flex;
  gap: 16rpx;
  align-items: flex-start;
}

.checkbox {
  width: 30rpx;
  height: 30rpx;
  border-radius: 6rpx;
  border: 2rpx solid #d4c3be;
  margin-top: 6rpx;
  box-sizing: border-box;
}

.checkbox.checked {
  background: #16b65a;
  border-color: #16b65a;
}

.agree-text {
  flex: 1;
  font-size: 24rpx;
  line-height: 1.55;
  color: #504441;
}

.link {
  color: #002e68;
  text-decoration: underline;
}
