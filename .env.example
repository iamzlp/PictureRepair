# ==============================================================================
# Runtime / Deployment
# ==============================================================================
ENVIRONMENT=development
AUTO_CREATE_TABLES=true
BACKEND_CORS_ORIGINS=*

# ==============================================================================
# Database Configuration
# ==============================================================================
POSTGRES_USER=budtrip
POSTGRES_PASSWORD=budtrip_password
POSTGRES_DB=pictureRepair
POSTGRES_HOST=localhost
POSTGRES_PORT=15432

# ==============================================================================
# Redis Configuration
# ==============================================================================
REDIS_HOST=localhost
REDIS_PORT=16379

# ==============================================================================
# MinIO Configuration (optional local object storage)
# ==============================================================================
STORAGE_TYPE=minio
MINIO_ROOT_USER=picturerepair_minio
MINIO_ROOT_PASSWORD=minio_password_123
MINIO_API_EXPOSE_PORT=19000
MINIO_CONSOLE_EXPOSE_PORT=19001
MINIO_ENDPOINT=http://localhost:19000
MINIO_BUCKET_NAME=picturerepair-assets
MINIO_SERVER_URL=

# ==============================================================================
# OSS Configuration
# ==============================================================================
OSS_ACCESS_KEY_ID=your_oss_access_key_id
OSS_ACCESS_KEY_SECRET=your_oss_access_key_secret
OSS_ENDPOINT=your_oss_endpoint
OSS_BUCKET_NAME=your_oss_bucket_name
OSS_PUBLIC_URL=your_oss_public_url

# ==============================================================================
# Volcengine / Ark Image Model
# ==============================================================================
VOLC_ACCESS_KEY=your_access_key_here
VOLC_SECRET_KEY=your_secret_key_here
ARK_API_KEY=your_ark_api_key_here
IMAGE_MODEL=doubao

# Set true while developing the mini program UI to avoid real model API cost.
MOCK_IMAGE_GENERATION=true

# ==============================================================================
# WeChat Mini Program
# ==============================================================================
WECHAT_APPID=your_wechat_appid
WECHAT_SECRET=your_wechat_secret
MOCK_WECHAT_LOGIN=true

# Payment testing switch. Keep false for normal mock business tests.
PAYMENT_USE_TEST_PRICES=false
PAYMENT_TEST_PRICE_SINGLE_1_CENTS=1
PAYMENT_TEST_PRICE_BUNDLE_30_CENTS=2
PAYMENT_TEST_PRICE_BUNDLE_90_CENTS=3

# Admin bootstrap for backend management API
ADMIN_INITIAL_USERNAME=
ADMIN_INITIAL_PASSWORD=
ADMIN_INITIAL_ROLE=super_admin

# ==============================================================================
# JWT
# ==============================================================================
SECRET_KEY=change-this-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=10080
